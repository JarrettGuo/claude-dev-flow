{
  "$comment": "项目级 Claude Code 设置。hooks 用来为 flow-log 能力提供自动记录。脚本位于 .claude/hooks/flow-log.sh。",
  "progressDisplay": {
    "enabled": true,
    "style": "full",
    "showTimeEstimate": true,
    "clearScreen": false
  },
  "hooks": {
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/flow-log.sh subagent-start \"$SUBAGENT_NAME\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/flow-log.sh subagent-stop \"$SUBAGENT_NAME\" \"$SUBAGENT_DURATION\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/flow-log.sh user-input \"$USER_PROMPT\""
          }
        ]
      }
    ]
  }
}
